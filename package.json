{
  "name": "mediatoolbox",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "start": "node scripts/start-dev.ts",
    "dev": "node scripts/start-dev.ts",
    "dev:full": "node scripts/start-dev.ts --real",
    "dev:frontend": "node scripts/start-frontend-dev.ts",
    "dev:real": "node scripts/start-frontend-dev.ts --real",
    "dev:backend": "npm --prefix backend run dev",
    "setup": "npm --prefix frontend install && npm --prefix backend install",
    "verify": "npm --prefix frontend run verify",
    "verify:backend": "npm --prefix backend run typecheck"
  }
}
